{
  "name": "@network-ai/native",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:fast": "vitest run --passWithNoTests --reporter=dot",
    "prebuild": "expo prebuild --clean"
  },
  "dependencies": {
    "@network-ai/app": "workspace:*",
    "@network-ai/ui": "workspace:*",
    "@network-ai/types": "workspace:*",
    "@supabase/supabase-js": "^2.50.0",
    "expo": "~54.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
