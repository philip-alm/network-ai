{
  "name": "@reknowable/app",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./features/*": "./src/features/*/index.ts",
    "./lib/*": "./src/lib/*/index.ts",
    "./lib/agent/nodeDebugRecorder": "./src/lib/agent/nodeDebugRecorder.ts"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --reporter=dot",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "1.0.39",
    "@reknowable/types": "workspace:*",
    "@reknowable/ui": "workspace:*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-virtual": "^3.13.24",
    "ai": "5.0.188",
    "idb": "^8.0.3",
    "lucide-react": "^0.469.0",
    "motion": "^11.18.2",
    "react": "18.3.1",
    "react-markdown": "^9.0.1",
    "react-native": "0.76.5",
    "remark-gfm": "^4.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@reknowable/test-utils": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "@types/react-native": "^0.73.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "react-dom": "18.3.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
