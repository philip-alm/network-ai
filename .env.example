# Public — safe in client bundle
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to client. Set in Supabase Edge Function secrets.
# SUPABASE_SERVICE_ROLE_KEY=
#
# LLM provider chain (agent-chat Edge Function). Primary → fallback ladder:
#   Cerebras GLM 4.7 → Groq gpt-oss-120b → Fireworks Kimi K2.5 → OpenRouter Gemini 3 Flash
# Set ALL FOUR for full reliability; tiers without keys are silently
# skipped at chain build time. At least one must be set.
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
# FIREWORKS_API_KEY=
# OPENROUTER_API_KEY=
